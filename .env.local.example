# Turso (libSQL) — https://turso.tech
# 1. Install CLI:  curl -sSfL https://get.tur.so/install.sh | bash
# 2. Login:        turso auth login
# 3. Create DB:    turso db create portfolio-visitors
# 4. Get URL:      turso db show portfolio-visitors --url
# 5. Get token:    turso db tokens create portfolio-visitors

TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# Admin session secret — must be at least 32 characters, keep private
# Generate one: openssl rand -base64 32
ADMIN_SESSION_SECRET=change-this-to-a-long-random-secret-string
